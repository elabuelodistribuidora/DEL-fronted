# ─────────────────────────────────────────────────────────────
#  Frontend — Distribuidora El Abuelo
#  Copiá este archivo a `.env.local` y completá los valores.
# ─────────────────────────────────────────────────────────────

# URL del backend (NestJS)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Google Maps — autocompletado de direcciones en el registro.
# Si está vacío, el registro usa carga manual de dirección (fallback).
# El lunes: crear proyecto en Google Cloud, habilitar "Maps JavaScript API"
# y "Places API", generar una API key y pegarla acá.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
